---
import type { SkillGroup } from "../data/profile";

interface Props {
  groups: SkillGroup[];
}

const { groups } = Astro.props;
---

<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
  {groups.map((group) => (
    <div>
      <h3 class="font-mono text-xs uppercase tracking-[0.2em] text-accent-muted mb-4">
        {group.category}
      </h3>
      <ul class="flex flex-wrap gap-2">
        {group.items.map((skill) => (
          <li class="rounded-sm border border-edge-mid bg-white px-3 py-1.5 font-mono text-xs text-accent-muted/80 shadow-subtle">
            {skill}
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
