    case "github":
      return `<path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>`;
    case "email":
      return `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>`;
    default:
      return "";
  }
}
---

<aside class="card rounded-sm p-6 flex flex-col items-center text-center">
  <!-- Profile Photo -->
  <div
    class="w-44 h-44 sm:w-48 sm:h-48 rounded-sm overflow-hidden border border-edge bg-surface-100 shadow-subtle mb-5"
  >
    <img
      src={profile.photoPath}
      alt="Photo of Chenzhe Zhang"
      class="w-full h-full object-cover"
      loading="eager"
    />
  </div>

  <!-- Name -->
  <h2 class="text-xl font-semibold text-accent">{profile.name}</h2>

  <!-- Subtitle -->
  <p class="mt-1.5 font-mono text-xs text-accent-muted/80 leading-relaxed">
    {profile.subtitle}<br />
    {profile.institution}
  </p>

  <!-- Divider -->
  <hr class="w-12 border-t border-edge my-5" />

  <!-- Social Links -->
  <nav class="w-full" aria-label="Social links">
    <ul class="space-y-1">
      {socialLinks.map((link) => (
        <li>
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 w-full px-3 py-2 rounded-sm font-mono text-xs text-accent-muted/70 transition-all hover:text-accent hover:bg-surface-100 focus-visible:outline-2 focus-visible:outline-accent-muted"
          >
            <span
              class="flex-shrink-0 text-accent-muted/50"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="currentColor"
                set:html={iconHref(link.icon)}
              />
            </span>
            <span>{link.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>
