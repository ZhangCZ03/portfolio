---
import type { Experience } from "../data/profile";

interface Props {
  items: Experience[];
}

const { items } = Astro.props;
---

<ol class="relative border-l border-edge-mid ml-3 space-y-10">
  {items.map((item) => (
    <li class="pl-8 relative">
      <!-- Timeline dot -->
      <span
        class="absolute left-0 top-1.5 -translate-x-1/2 flex h-2.5 w-2.5 items-center justify-center rounded-full bg-accent-muted ring-4 ring-surface-50"
        aria-hidden="true"
      ></span>

      <!-- Date -->
      <span class="block font-mono text-xs text-accent-muted/50 tracking-wide mb-1.5">
        {item.dateRange}
      </span>

      <!-- Title -->
      <h3 class="text-base font-semibold text-accent">{item.title}</h3>

      <!-- Institution -->
      <p class="mt-0.5 font-mono text-xs text-accent-muted">{item.institution}</p>

      <!-- Description -->
      <p class="mt-2 text-sm leading-relaxed text-accent-muted/80 max-w-xl">
        {item.description}
      </p>
    </li>
  ))}
</ol>
