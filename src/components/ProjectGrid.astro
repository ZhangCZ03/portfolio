---
import type { Project } from "../data/profile";
import ProjectCard from "./ProjectCard.astro";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {projects.map((project) => (
    <ProjectCard {...project} />
  ))}
</div>
