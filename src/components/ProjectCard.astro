---
import type { Project } from "../data/profile";

const { title, description, tags } = Astro.props as Project;
---

<article class="card group rounded-sm flex flex-col">
  <!-- Accent bar -->
  <div class="h-1 w-full bg-accent/20 group-hover:bg-accent/40 transition-colors rounded-t-sm" aria-hidden="true"></div>

  <div class="flex flex-1 flex-col p-6">
    <!-- Title -->
    <h3 class="text-lg font-semibold text-accent transition-colors group-hover:text-accent-hover">
      {title}
    </h3>

    <!-- Description -->
    <p class="mt-3 flex-1 text-sm leading-relaxed text-accent-muted/80">
      {description}
    </p>

    <!-- Tags -->
    <div class="mt-5 flex flex-wrap gap-2">
      {tags.map((tag: string) => (
        <span class="tag-pill">
          {tag}
        </span>
      ))}
    </div>
  </div>
</article>
