---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEOTags from "../components/SEOTags.astro";
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  image?: string;
  path?: string;
}

const { title, description, image, path } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEOTags title={title} description={description} image={image} path={path} />
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
